{
  "manifest_version": 3,
  "name": "Qianwen Audio Helper",
  "version": "1.1.0",
  "description": "Upload selected local audio files to Qianwen audio reading.",
  "permissions": ["tabs", "storage", "windows"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://www.qianwen.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.qianwen.com/discover/audioread*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Qianwen Audio Helper",
    "default_popup": "popup.html"
  }
}
